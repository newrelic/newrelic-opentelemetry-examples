# New Relic API key to authenticate the export requests.
# docs: https://docs.newrelic.com/docs/apis/intro-apis/new-relic-api-keys/#license-key
NEW_RELIC_LICENSE_KEY=INSERT_API_KEY

# For EU accounts, use: https://otlp.eu01.nr-data.net
# docs: https://docs.newrelic.com/docs/more-integrations/open-source-telemetry-integrations/opentelemetry/best-practices/opentelemetry-otlp/#configure-endpoint-port-protocol
NEW_RELIC_OTLP_ENDPOINT=https://otlp.nr-data.net

# OpenAI API key for chat completions.
# docs: https://platform.openai.com/api-keys
OPENAI_API_KEY=INSERT_OPENAI_API_KEY

# Optional: Override the default chat model (defaults to gpt-4o-mini)
# CHAT_MODEL=gpt-4o-mini
